---
// Minimal hero — one-liner CTA strip linking to goldrush.dev
---

<div class="hero-strip">
    <span class="hero-line">
        Multichain data APIs for builders, traders, and agents.
    </span>
    <a
        href="https://goldrush.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="hero-cta"
    >Start building →</a>
</div>

<style>
    .hero-strip {
        display: flex;
        align-items: center;
        gap: var(--spacing-04);
        padding: var(--spacing-04) var(--spacing-09);
        border-bottom: 0.5px solid var(--border-muted);
        flex-wrap: wrap;
    }

    .hero-line {
        font-size: var(--desktop-body-sm);
        font-family: var(--monospace);
        color: var(--content-secondary-alt);
        letter-spacing: 0.01em;
    }

    .hero-cta {
        font-size: var(--desktop-body-sm);
        font-family: var(--monospace);
        color: DarkOrange;
        text-decoration: none;
        letter-spacing: 0.01em;
        white-space: nowrap;
        transition: opacity 0.15s ease;
    }

    .hero-cta:hover {
        opacity: 0.8;
    }

    @media (max-width: 48rem) {
        .hero-strip {
            padding: var(--spacing-03) var(--spacing-06);
            gap: var(--spacing-03);
        }
    }
</style>
