---
import Layout from "../layouts/Layout.astro";

import Dashboard from "../components/Dashboard";
import RecentlyViewed from "../components/RecentlyViewed";
import OrganizationSchema from "../components/schema/OrganizationSchema.astro";
import ItemListSchema from "../components/schema/ItemListSchema.astro";
import data from "../data/tools.json";

// Flatten all tools for the homepage ItemList
const allTools = data.tools.flatMap((category: any) => category.content);
---

<Layout
  site="GoldRush Skills"
  title="GoldRush Skills"
  tagline="Skills to build anything onchain — powered by GoldRush"
  showSearch={true}
  pageTitle="GoldRush Skills — Build anything onchain"
  pageDescription="132 copy-paste code skills for building onchain products with GoldRush. Wallets, DeFi, NFTs, AI agents, and more — across 200+ chains."
  canonicalUrl="https://skills.goldrush.dev"
  ogTitle="GoldRush Skills — Build anything onchain"
  ogDescription="132 copy-paste code skills for building onchain products with GoldRush. Wallets, DeFi, NFTs, AI agents, and more — across 200+ chains."
  ogImage="https://skills.goldrush.dev/og.svg"
  ogUrl="https://skills.goldrush.dev"
  ogType="website"
  ogSiteName="GoldRush Skills"
  twitterCard="summary_large_image"
  twitterTitle="GoldRush Skills — Build anything onchain"
  twitterDescription="132 copy-paste code skills for building onchain products with GoldRush. Wallets, DeFi, NFTs, AI agents — 200+ chains."
  twitterImage="https://skills.goldrush.dev/og.svg"
>
  <OrganizationSchema />
  <ItemListSchema items={allTools} listName="GoldRush Skills Directory - All Skills" />
  <main id="main-content">
    <RecentlyViewed client:load />
    <Dashboard client:load category="all" transition:persist />
  </main>
</Layout>
