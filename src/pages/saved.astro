---
import Layout from "../layouts/Layout.astro";
import FavoritesView from "../components/FavoritesView";
import BreadcrumbSchema from "../components/schema/BreadcrumbSchema.astro";

const breadcrumbs = [
    { name: "Home", url: "https://goldrush.dev" },
    { name: "Saved skills" },
];
---

<Layout
    site="GoldRush Skills - Saved skills"
    title="Saved skills"
    tagline="Skills you've saved for quick access"
    pageTitle="Saved skills"
    pageDescription="Your saved GoldRush skills collection"
>
    <BreadcrumbSchema items={breadcrumbs} />
    <main id="main-content">
        <FavoritesView client:load />
    </main>
</Layout>
