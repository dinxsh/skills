---
import Layout from "../../layouts/Layout.astro";
import { Code } from "astro:components";
import slugMap from "../../data/slug-map.json";
import skillPairs from "../../data/skill-pairs.json";
import skillKits from "../../data/skill-kits.json";
import SoftwareApplicationSchema from "../../components/schema/SoftwareApplicationSchema.astro";
import BreadcrumbSchema from "../../components/schema/BreadcrumbSchema.astro";
import BookmarkButton from "../../components/BookmarkButton";

export async function getStaticPaths() {
  // Use slug-map for efficient path generation (no need to load full tools.json)
  const slugMapData = await import("../../data/slug-map.json");
  const paths = Object.keys(slugMapData.default).map((slug) => ({
    params: { slug },
  }));

  return paths;
}

export const prerender = true;

const { slug } = Astro.params;

// Use slug-map to find category
const categoryList = (slugMap as Record<string, string[]>)[slug as string];
const categoryName = categoryList?.[0];

if (!categoryName) {
  throw new Error(`Tool not found: ${slug}`);
}

// Dynamically import only the needed category file
const categoryTools = await import(`../../data/tools/${categoryName}.json`);
const found = categoryTools.default.find((x: any) => x.slug === slug) || null;

if (!found) {
  throw new Error(`Tool not found: ${slug}`);
}

const tool = found;
const category = categoryName;

const extractDomain = (url: string) => {
  try {
    return new URL(url).hostname.replace("www.", "");
  } catch {
    return "";
  }
};
const formatDate = (dateStr: string) => {
  try {
    return new Date(dateStr).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  } catch {
    return dateStr;
  }
};

const domain = extractDomain(tool.url || "");
const formattedDate = formatDate(tool["date-added"]);
const canonicalUrl = `https://skills.goldrush.dev/tools/${tool.slug}`;
const faviconUrl = `/favicons/${slug}.png`;
const fallbackPath = category === "all" ? "/" : `/${category}`;

let meta: any = {};
try {
  const toolMetadata = await import(`../../data/tool-metadata/${slug}.json`);
  meta = toolMetadata.default;
} catch (e) {}

const seoTitle = meta.title || tool.title;
const seoDescription = meta.description || tool.body;
const seoOgImage = "https://skills.goldrush.dev/og.svg";
const seoOgType = "website";

// Kit membership
type KitEntry = { id: string; title: string; emoji: string; complexity: string };
const kitMemberships: KitEntry[] = (skillKits as Record<string, KitEntry[]>)[slug as string] ?? [];

// Rich skill metadata
const snippet: string | null = meta.snippet || null;
const endpoints: string[] = meta.endpoints || [];
const chains: string[] = meta.chains || [];
const complexity: string | null = meta.complexity || null;
const useCase: string | null = meta.useCase || null;
const buildsWith: string[] = meta.buildsWith || [];
const creditCost: string | null = meta.creditCost || null;
const keyParams: Record<string, string> | null = meta.keyParams || null;
const responseFields: string[] = meta.responseFields || [];

// Generate one-shot Claude prompt
const chainList = chains.length > 0 ? chains : ["ethereum", "polygon", "base", "arbitrum", "optimism"];
const chainDropdownOptions = chainList.map(c => {
  const chainNameMap: Record<string, string> = {
    ethereum: "eth-mainnet", polygon: "matic-mainnet", base: "base-mainnet",
    arbitrum: "arbitrum-mainnet", optimism: "optimism-mainnet", bsc: "bsc-mainnet",
    avalanche: "avalanche-mainnet", solana: "solana-mainnet",
  };
  return `{ label: "${c.charAt(0).toUpperCase() + c.slice(1)}", value: "${chainNameMap[c] ?? c + "-mainnet"}" }`;
}).join(", ");
const keyParamsText = keyParams
  ? Object.entries(keyParams).map(([k, v]) => `  - ${k}: ${v}`).join("\n")
  : "";
const responseFieldsText = responseFields.map(f => `  - ${f}`).join("\n");
const endpointsText = endpoints.map(e => `  ${e}`).join("\n");

const claudePrompt = `Build a production-ready "${tool.title}" web application using the GoldRush SDK.

## Goal
${meta.description || tool.body}

## Use case
${useCase || tool.body}

## Tech stack
- Next.js 14 App Router + TypeScript + Tailwind CSS
- @covalenthq/client-sdk (GoldRush SDK v3)
- Environment variable: GOLDRUSH_API_KEY

## Chain switcher requirement
Add a dropdown that lets the user switch chains. Options:
const CHAINS = [${chainDropdownOptions}];

When the chain changes, re-fetch data automatically. Default to the first chain.

## Starting code
\`\`\`typescript
${snippet || `import { GoldRushClient } from '@covalenthq/client-sdk';
const client = new GoldRushClient(process.env.GOLDRUSH_API_KEY!);`}
\`\`\`

## API endpoints used
${endpointsText || `  See GoldRush docs at goldrush.dev`}${creditCost ? `\n\nCredit cost: ${creditCost}` : ""}

## Key parameters to expose in the UI
${keyParamsText || "  See GoldRush docs"}

## Response fields to display
${responseFieldsText || "  See GoldRush docs"}

## UI requirements
1. Chain dropdown at the top — switching it re-fetches immediately
2. Loading skeleton while fetching
3. Error state with retry button
4. Display all response fields listed above in a clean table or card layout
5. Show USD values formatted as $x,xxx.xx
6. Responsive layout (works on mobile)
7. Input field for wallet address (default to "vitalik.eth")

## Code quality
- Full TypeScript types for all GoldRush response shapes
- async/await with proper error handling (check error before data)
- No any types — use GoldRush SDK types
- Extract the GoldRush client to a lib/goldrush.ts singleton

Build the complete app: page component, any server actions or API routes needed, and the chain switcher component. Make it ready to deploy on Vercel.`;

// Resolve buildsWith slugs to tool objects
const buildsWithTools: any[] = [];
for (const bSlug of buildsWith.slice(0, 4)) {
  const bCategory = (slugMap as Record<string, string[]>)[bSlug]?.[0];
  if (!bCategory) continue;
  try {
    const bCat = await import(`../../data/tools/${bCategory}.json`);
    const bTool = bCat.default.find((x: any) => x.slug === bSlug);
    if (bTool) buildsWithTools.push({ ...bTool, category: bCategory });
  } catch {}
}
const seoOgSiteName = "GoldRush Skills";

const encodedShareText = encodeURIComponent(
  `Check out ${tool.title} - ${tool.body}`,
);
const encodedCanonicalUrl = encodeURIComponent(canonicalUrl);
const xShareUrl = `https://x.com/intent/post?text=${encodedShareText}&url=${encodedCanonicalUrl}&via=covalenthq`;
const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedCanonicalUrl}`;
const redditShareUrl = `https://www.reddit.com/submit?url=${encodedCanonicalUrl}&title=${encodedShareText}`;

// Resolve "pairs well with" from kit co-occurrence, fall back to same-category
const pairSlugs: string[] = (skillPairs as Record<string, string[]>)[slug as string] ?? [];
const relatedTools: any[] = [];
for (const pairSlug of pairSlugs.slice(0, 4)) {
  const pairCategory = (slugMap as Record<string, string[]>)[pairSlug]?.[0];
  if (!pairCategory) continue;
  try {
    const pairCat = await import(`../../data/tools/${pairCategory}.json`);
    const pairTool = pairCat.default.find((x: any) => x.slug === pairSlug);
    if (pairTool) relatedTools.push({ ...pairTool, category: pairCategory });
  } catch {}
}
if (relatedTools.length === 0) {
  const allCategoryTools = categoryTools.default || [];
  const otherTools = allCategoryTools.filter((t: any) => t.slug !== slug);
  relatedTools.push(...otherTools.sort(() => Math.random() - 0.5).slice(0, 4));
}

const categoryTitle = category.charAt(0).toUpperCase() + category.slice(1);
const breadcrumbs = [
  { name: "Home", url: "https://goldrush.dev" },
  { name: categoryTitle, url: `https://goldrush.dev/${category}` },
  { name: tool.title },
];
---

<Layout
  site={`GoldRush Skills - ${tool.title}`}
  title={tool.title}
  tagline={tool.body}
  pageTitle={seoTitle}
  pageDescription={seoDescription}
  canonicalUrl={canonicalUrl}
  ogTitle={seoTitle}
  ogDescription={seoDescription}
  ogUrl={canonicalUrl}
  ogImage={seoOgImage}
  ogType={seoOgType}
  ogSiteName={seoOgSiteName}
  twitterCard="summary_large_image"
  twitterTitle={seoTitle}
  twitterDescription={seoDescription}
  twitterImage={seoOgImage}
  pageFavicon={faviconUrl}
>
  <SoftwareApplicationSchema
    name={tool.title}
    description={tool.body}
    url={tool.url}
    tag={tool.tag}
    dateAdded={tool["date-added"]}
    category={category}
  />
  <BreadcrumbSchema items={breadcrumbs} />
  <main id="main-content">
    <div class="modal-backdrop" id="modalBackdrop">
      <div class="modal" id="toolModal" data-fallback={fallbackPath} data-skill-slug={slug} data-skill-category={category}>

        <!-- Header -->
        <div class="modal-header">
          <div class="modal-header-left">
            <h1 class="modal-title">{tool.title}</h1>
            <div class="modal-meta">
              <a href={`/${category}`} class="badge">{categoryTitle}</a>
              {complexity && (
                <span class={`badge badge--${complexity.toLowerCase()}`}>{complexity}</span>
              )}
              <span class="meta-sep">·</span>
              <span class="meta-muted">Added {formattedDate}</span>
            </div>
          </div>
          <button class="modal-close" title="Close (ESC)" aria-label="Close tool details">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <!-- Body -->
        <div class="modal-body">

          <p class="description">{meta.description || tool.body}</p>

          {useCase && (
            <div class="field">
              <span class="field-label">Use case</span>
              <p class="field-text">{useCase}</p>
            </div>
          )}

          {chains.length > 0 && (
            <div class="field field--row">
              <span class="field-label">Chains</span>
              <div class="chips">
                {chains.map((c) => <span class="chip">{c}</span>)}
              </div>
            </div>
          )}

          {kitMemberships.length > 0 && (
            <div class="field field--row">
              <span class="field-label">Kits</span>
              <div class="chips">
                {kitMemberships.map(k => (
                  <a href={`/kits/${k.id}`} class="chip chip--kit">{k.emoji} {k.title}</a>
                ))}
              </div>
            </div>
          )}

          <!-- Meta row -->
          <div class="meta-strip">
            <div class="meta-item">
              <span class="field-label">Access</span>
              <span class="meta-val">{tool.tag}</span>
            </div>
            {creditCost && (
              <div class="meta-item">
                <span class="field-label">Cost</span>
                <span class="meta-val meta-val--accent">{creditCost}</span>
              </div>
            )}
            {tool.url && (
              <div class="meta-item">
                <span class="field-label">Docs</span>
                <a href={tool.url} target="_blank" rel="noopener noreferrer" class="meta-val meta-val--link">
                  {domain || tool.url}
                </a>
              </div>
            )}
          </div>

          <!-- Claude prompt -->
          <div class="prompt-block">
            <div class="prompt-head">
              <span class="prompt-label">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                Claude prompt
              </span>
              <button class="btn-copy" id="copyClaudeBtn">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="currentColor" viewBox="0 0 256 256"><path d="M216,32H88a8,8,0,0,0-8,8V80H40a8,8,0,0,0-8,8V216a8,8,0,0,0,8,8H168a8,8,0,0,0,8-8V176h40a8,8,0,0,0,8-8V40A8,8,0,0,0,216,32ZM160,208H48V96H160Zm48-48H176V88a8,8,0,0,0-8-8H96V48H208Z"/></svg>
                <span class="copy-claude-label">Copy prompt</span>
              </button>
              <button class="btn-copy" id="downloadClaudeBtn" title="Download prompt as .md">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="currentColor" viewBox="0 0 256 256"><path d="M224,144v64a8,8,0,0,1-8,8H40a8,8,0,0,1-8-8V144a8,8,0,0,1,16,0v56H208V144a8,8,0,0,1,16,0Zm-101.66,5.66a8,8,0,0,0,11.32,0l40-40a8,8,0,0,0-11.32-11.32L136,124.69V32a8,8,0,0,0-16,0v92.69L93.66,98.34a8,8,0,0,0-11.32,11.32Z"/></svg>
                <span class="download-claude-label">.md</span>
              </button>
            </div>
            <p class="prompt-hint">Paste into Claude → complete Next.js app with chain switching.</p>
            <textarea id="claudePromptText" readonly class="prompt-textarea">{claudePrompt}</textarea>
            <div class="post-copy-steps" id="postCopySteps" style="display:none">
              <span class="post-copy-label">Next</span>
              <a id="openClaudeBtn" href="https://claude.ai/new" target="_blank" rel="noopener noreferrer" class="post-copy-btn">Open in Claude →</a>
              <a href="https://goldrush.dev/platform/auth/register" target="_blank" rel="noopener noreferrer" class="post-copy-step">Get free API key →</a>
              <a href="https://vercel.com/new" target="_blank" rel="noopener noreferrer" class="post-copy-step">Deploy on Vercel →</a>
            </div>
          </div>

          {snippet && (
            <div class="code-wrap">
              <div class="code-head">
                <span class="field-label">Quick start</span>
                <button class="btn-copy" id="copySnippetBtn">
                  <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="currentColor" viewBox="0 0 256 256"><path d="M216,32H88a8,8,0,0,0-8,8V80H40a8,8,0,0,0-8,8V216a8,8,0,0,0,8,8H168a8,8,0,0,0,8-8V176h40a8,8,0,0,0,8-8V40A8,8,0,0,0,216,32ZM160,208H48V96H160Zm48-48H176V88a8,8,0,0,0-8-8H96V48H208Z"/></svg>
                  <span class="copy-label">Copy</span>
                </button>
              </div>
              <div class="code-shiki" id="snippetCode" data-raw={snippet}>
                <Code code={snippet} lang="typescript" theme="github-dark-dimmed" />
              </div>
            </div>
          )}

          {endpoints.length > 0 && (
            <div class="field">
              <span class="field-label">Endpoints</span>
              <ul class="endpoint-list">
                {endpoints.map((ep) => (
                  <li><code class="endpoint-code">{ep}</code></li>
                ))}
              </ul>
            </div>
          )}

          {keyParams && Object.keys(keyParams).length > 0 && (
            <div class="field">
              <span class="field-label">Key parameters</span>
              <dl class="params-dl">
                {Object.entries(keyParams).map(([key, desc]) => (
                  <div class="param-row">
                    <dt><code class="param-key">{key}</code></dt>
                    <dd class="param-desc">{desc}</dd>
                  </div>
                ))}
              </dl>
            </div>
          )}

          {responseFields.length > 0 && (
            <div class="field">
              <span class="field-label">Response fields</span>
              <ul class="response-list">
                {responseFields.map((f) => (
                  <li><code class="response-code">{f}</code></li>
                ))}
              </ul>
            </div>
          )}

          {(buildsWithTools.length > 0 || relatedTools.length > 0) && (
            <div class="field">
              <span class="field-label">{buildsWithTools.length > 0 ? "Combine with" : "More skills"}</span>
              <div class="related-grid">
                {(buildsWithTools.length > 0 ? buildsWithTools : relatedTools).map((t: any) => (
                  <a href={`/tools/${t.slug}`} class="related-card" data-astro-history="replace">
                    <span class="related-name">{t.title}</span>
                    <span class="related-tag">{t.tag}</span>
                  </a>
                ))}
              </div>
            </div>
          )}

        </div>

        <!-- Footer -->
        <div class="modal-footer">
          <a href={category === "all" ? "/" : `/${category}`} class="btn-back">← Back</a>
          <div class="footer-right">
            <button class="icon-btn" id="copySpecBtn" title="Copy skill spec JSON" aria-label="Copy skill spec">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 256 256"><path d="M69.12,94.15,28.5,128l40.62,33.85a8,8,0,1,1-10.24,12.29l-48-40a8,8,0,0,1,0-12.29l48-40a8,8,0,0,1,10.24,12.3Zm176,27.7-48-40a8,8,0,1,0-10.24,12.3L227.5,128l-40.62,33.85a8,8,0,1,0,10.24,12.29l48-40a8,8,0,0,0,0-12.29ZM162.73,32.48a8,8,0,0,0-10.25,4.79l-64,176a8,8,0,0,0,4.79,10.26A8.14,8.14,0,0,0,96,224a8,8,0,0,0,7.52-5.27l64-176A8,8,0,0,0,162.73,32.48Z"/></svg>
            </button>
            <a href={xShareUrl} target="_blank" rel="noopener noreferrer" class="icon-btn" title="Share on X" aria-label="Share on X">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 256 256"><path d="M214.75,211.71l-62.6-98.38,61.77-67.95a8,8,0,0,0-11.84-10.76L143.24,99.34,102.75,35.71A8,8,0,0,0,96,32H48a8,8,0,0,0-6.75,12.3l62.6,98.37-61.77,68a8,8,0,1,0,11.84,10.76l58.84-64.72,40.49,63.63A8,8,0,0,0,160,224h48a8,8,0,0,0,6.75-12.29ZM164.39,208,62.57,48h29L193.43,208Z"/></svg>
            </a>
            <button class="icon-btn" id="copyLinkBtn" title="Copy link" aria-label="Copy link to clipboard">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 256 256"><path d="M240,88.23a54.43,54.43,0,0,1-16,37L189.25,160a54.27,54.27,0,0,1-38.63,16h-.05A54.63,54.63,0,0,1,96,119.84a8,8,0,0,1,16,.45A38.62,38.62,0,0,0,150.58,160h0a38.39,38.39,0,0,0,27.31-11.31l34.75-34.75a38.63,38.63,0,0,0-54.63-54.63l-11,11A8,8,0,0,1,135.7,59l11-11A54.65,54.65,0,0,1,224,48,54.86,54.86,0,0,1,240,88.23ZM109,185.66l-11,11A38.41,38.41,0,0,1,70.6,208h0a38.63,38.63,0,0,1-27.29-65.94L78,107.31A38.63,38.63,0,0,1,144,135.71a8,8,0,0,0,16,.45A54.86,54.86,0,0,0,144,96a54.65,54.65,0,0,0-77.27,0L32,130.75A54.62,54.62,0,0,0,70.56,224h0a54.28,54.28,0,0,0,38.64-16l11-11A8,8,0,0,0,109,185.66Z"/></svg>
            </button>
            <BookmarkButton client:load slug={slug} title={tool.title} variant="default" />
            {tool.url ? (
              <a href={tool.url} target="_blank" rel="noopener noreferrer" class="btn-primary">Open docs →</a>
            ) : (
              <span class="btn-primary btn-disabled">No website</span>
            )}
          </div>
        </div>

      </div>
    </div>
  </main>

  <script id="skillSpecData" type="application/json" set:html={JSON.stringify(meta, null, 2)}></script>

  <script type="module">
    function closeModal() {
      document.body.removeAttribute("data-modal-open");
      document.body.style.overflow = "";

      if (window.history.length > 1) window.history.back();
      else
        window.location.href =
          document.getElementById("toolModal")?.dataset.fallback || "/";
    }

    function handleInteraction(e) {
      if (
        e.target.closest(".modal-close") ||
        (e.target.closest(".modal-backdrop") &&
          !e.target.closest(".modal"))
      ) {
        e.preventDefault();
        return closeModal();
      }

      const copyBtn = e.target.closest("#copyLinkBtn");
      if (copyBtn) {
        navigator.clipboard.writeText(window.location.href).then(() => {
          const original = copyBtn.innerHTML;
          copyBtn.innerHTML =
            '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>';
          setTimeout(() => (copyBtn.innerHTML = original), 2000);
        });
      }

      const snippetBtn = e.target.closest("#copySnippetBtn");
      if (snippetBtn) {
        const code = document.getElementById("snippetCode")?.dataset.raw || "";
        navigator.clipboard.writeText(code).then(() => {
          const label = snippetBtn.querySelector(".copy-label");
          if (label) { label.textContent = "Copied!"; setTimeout(() => (label.textContent = "Copy"), 2000); }
          if (typeof window.gtag === "function") {
            window.gtag("event", "skill_snippet_copy", {
              skill_slug: document.querySelector("[data-skill-slug]")?.dataset.skillSlug ?? "",
            });
          }
        });
      }

      const copySpecBtn = e.target.closest("#copySpecBtn");
      if (copySpecBtn) {
        const spec = document.getElementById("skillSpecData")?.textContent || "";
        navigator.clipboard.writeText(spec).then(() => {
          const original = copySpecBtn.innerHTML;
          copySpecBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>';
          setTimeout(() => (copySpecBtn.innerHTML = original), 2000);
          window.gtag?.("event", "skill_spec_copy", { skill_slug: document.querySelector("[data-skill-slug]")?.dataset.skillSlug ?? "" });
        });
      }

      const downloadBtn = e.target.closest("#downloadClaudeBtn");
      if (downloadBtn) {
        const promptEl = document.getElementById("claudePromptText");
        const text = promptEl ? promptEl.value : "";
        const skillSlug = document.querySelector("[data-skill-slug]")?.dataset.skillSlug ?? "skill";
        const blob = new Blob([text], { type: "text/markdown;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url; a.download = `${skillSlug}-prompt.md`; a.click();
        URL.revokeObjectURL(url);
      }

      const claudeBtn = e.target.closest("#copyClaudeBtn");
      if (claudeBtn) {
        const promptEl = document.getElementById("claudePromptText");
        const text = promptEl ? promptEl.value : "";
        navigator.clipboard.writeText(text).then(() => {
          const label = claudeBtn.querySelector(".copy-claude-label");
          if (label) { label.textContent = "Copied!"; setTimeout(() => (label.textContent = "Copy prompt"), 2500); }
          // Show next-steps panel
          const nextSteps = document.getElementById("postCopySteps");
          if (nextSteps) { nextSteps.style.display = "flex"; }
          // GA4 event
          if (typeof window.gtag === "function") {
            window.gtag("event", "skill_prompt_copy", {
              skill_slug: document.querySelector("[data-skill-slug]")?.dataset.skillSlug ?? "",
              skill_category: document.querySelector("[data-skill-category]")?.dataset.skillCategory ?? "",
            });
          }
        });
      }
    }

    function handleKeydown(e) {
      if (e.key === "Escape") closeModal();
    }

    function cleanup() {
      document.removeEventListener("click", handleInteraction);
      document.removeEventListener("keydown", handleKeydown);
      document.body.removeAttribute("data-modal-open");
      document.body.style.overflow = "";
    }

    function init() {
      const modal = document.getElementById("toolModal");
      if (!modal) return;

      // Ensure fresh state
      cleanup();

      const backdrop = document.getElementById("modalBackdrop");
      if (backdrop) backdrop.scrollTop = 0;

      document.body.setAttribute("data-modal-open", "true");
      document.body.style.overflow = "hidden";

      document.addEventListener("click", handleInteraction);
      document.addEventListener("keydown", handleKeydown);
    }

    // Track recently viewed
    (function trackRecentlyViewed() {
      try {
        const slug = document.querySelector("[data-skill-slug]")?.dataset.skillSlug;
        if (!slug) return;
        const raw = localStorage.getItem("recently_viewed");
        const arr = raw ? JSON.parse(raw) : [];
        const filtered = arr.filter((s) => s !== slug);
        localStorage.setItem("recently_viewed", JSON.stringify([slug, ...filtered].slice(0, 8)));
      } catch {}
    })();

    // Initialize on load
    init();

    // Re-initialize on ViewTransitions navigation
    document.addEventListener("astro:page-load", init);

    // Clean up when navigating away or hidden
    document.addEventListener("astro:before-preparation", cleanup);
    window.addEventListener("pagehide", cleanup);
  </script>

