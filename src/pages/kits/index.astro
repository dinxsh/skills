---
import Layout from "../../layouts/Layout.astro";
import kitsData from "../../data/kits.json";

const complexityCounts = {
  all: kitsData.kits.length,
  beginner: kitsData.kits.filter(k => k.complexity === 'Beginner').length,
  intermediate: kitsData.kits.filter(k => k.complexity === 'Intermediate').length,
  advanced: kitsData.kits.filter(k => k.complexity === 'Advanced').length,
};
---

<Layout
  site="GoldRush Skills"
  title="Starter Kits"
  tagline="Pre-composed skill bundles for building complete onchain apps with one Claude prompt."
  pageTitle="Starter Kits — GoldRush Skills"
  pageDescription="18 pre-composed GoldRush skill bundles for building complete onchain apps in one shot. DeFi dashboard, NFT portfolio, whale intelligence, tax reporter, DAO governance, and more."
  canonicalUrl="https://skills.goldrush.dev/kits"
  ogTitle="Starter Kits — GoldRush Skills"
  ogDescription="Pre-composed skill bundles for building complete onchain apps with one Claude prompt."
>
  <main id="main-content" class="kits-page">
    <div class="kits-header">
      <a href="/" class="kits-back">← All skills</a>
      <h1 class="kits-title">Starter Kits</h1>
      <p class="kits-subtitle">18 pre-composed bundles of 6 GoldRush skills each. Copy one prompt, build a complete deployable app.</p>
      <div class="kits-search-row">
        <input type="search" id="kitsSearch" placeholder="Search kits…" class="kits-search" autocomplete="off" />
      </div>
      <div class="kits-filters" id="kitsFilters">
        <button class="kits-filter kits-filter--active" data-filter="all">All <span>{complexityCounts.all}</span></button>
        <button class="kits-filter" data-filter="beginner">Beginner <span>{complexityCounts.beginner}</span></button>
        <button class="kits-filter" data-filter="intermediate">Intermediate <span>{complexityCounts.intermediate}</span></button>
        <button class="kits-filter" data-filter="advanced">Advanced <span>{complexityCounts.advanced}</span></button>
      </div>
    </div>

    <div class="kits-grid" id="kitsGrid">
      {kitsData.kits.map(kit => (
        <a href={`/kits/${kit.id}`} class="kit-card" data-complexity={kit.complexity.toLowerCase()}>
          <div class="kit-card-top">
            <span class="kit-card-emoji">{kit.emoji}</span>
            <span class={`kit-card-complexity kit-card-complexity--${kit.complexity.toLowerCase()}`}>{kit.complexity}</span>
          </div>
          <strong class="kit-card-title">{kit.title}</strong>
          <p class="kit-card-desc">{kit.description}</p>
          <div class="kit-card-footer">
            <span class="kit-card-count">{kit.skills.length} skills</span>
            <div class="kit-card-chains">
              {kit.chains.slice(0, 4).map(c => (
                <span class="kit-card-chain">{c}</span>
              ))}
              {kit.chains.length > 4 && <span class="kit-card-chain">+{kit.chains.length - 4}</span>}
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>

  <style>
    .kits-page { max-width: 60rem; margin: var(--spacing-05) auto; padding: 0 var(--spacing-09); }
    .kits-back { font-family: var(--monospace); font-size: 0.7rem; color: var(--content-secondary); text-decoration: none; }
    .kits-back:hover { color: var(--content-primary); }
    .kits-header { margin-bottom: var(--spacing-05); }
    .kits-title {
      margin: var(--spacing-03) 0 var(--spacing-02);
      font-size: 1.25rem;
      font-family: var(--monospace);
      font-weight: 700;
      color: var(--content-primary);
      letter-spacing: -0.01em;
    }
    .kits-subtitle { margin: 0; color: var(--content-secondary); font-size: 0.8rem; line-height: 1.5; }
    .kits-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr)); gap: var(--spacing-03); }
    .kit-card {
      display: flex; flex-direction: column; gap: var(--spacing-02);
      padding: var(--spacing-04) var(--spacing-05);
      background: var(--background); border: 0.5px solid var(--border-muted);
      text-decoration: none;
      transition: border-color 0.15s, background-color 0.15s, box-shadow 0.15s;
    }
    .kit-card:hover { border-color: var(--border); background-color: var(--background-secondary); box-shadow: 0 2px 12px rgba(0,0,0,0.18); }
    .kit-card-top { display: flex; align-items: center; justify-content: space-between; }
    .kit-card-emoji { font-size: 1.1rem; }
    .kit-card-complexity { font-family: var(--monospace); font-size: 0.58rem; padding: 1px 5px; letter-spacing: 0.03em; }
    .kit-card-complexity--beginner     { background: rgba(110,224,110,.08); color: #6ee06e; }
    .kit-card-complexity--intermediate { background: rgba(224,200,78,.08);  color: #e0c84e; }
    .kit-card-complexity--advanced     { background: rgba(224,110,110,.08); color: #e06e6e; }
    .kit-card-title { color: var(--content-primary); font-size: 0.9rem; font-weight: 600; line-height: 1.3; letter-spacing: -0.01em; }
    .kit-card-desc { margin: 0; color: var(--content-secondary); font-size: 0.75rem; line-height: 1.5; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .kit-card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: var(--spacing-02); padding-top: var(--spacing-02); border-top: 0.5px solid var(--border-muted); }
    .kit-card-count { font-family: var(--monospace); font-size: 0.6rem; color: var(--content-secondary-alt); }
    .kit-card-chains { display: flex; gap: 3px; flex-wrap: wrap; }
    .kit-card-chain { font-family: var(--monospace); font-size: 0.58rem; color: var(--content-secondary-alt); padding: 0 4px; background: var(--background-secondary); border: 0.5px solid var(--border-muted); }
    .kits-filters { display: flex; gap: var(--spacing-02); margin-top: var(--spacing-03); flex-wrap: wrap; }
    .kits-filter { background: none; border: 0.5px solid var(--border-muted); color: var(--content-secondary); font-family: var(--monospace); font-size: 0.65rem; padding: 0 var(--spacing-03); height: 1.5rem; cursor: pointer; transition: border-color 0.15s, color 0.15s; letter-spacing: 0.02em; }
    .kits-filter span { opacity: 0.5; margin-left: 3px; }
    .kits-filter:hover { border-color: var(--border); color: var(--content-primary); }
    .kits-filter--active { border-color: DarkOrange; color: DarkOrange; }
    .kits-filter--active span { opacity: 0.7; }
    .kit-card[hidden] { display: none; }
    .kits-search-row { margin-top: var(--spacing-04); }
    .kits-search {
      background: var(--background);
      border: 0.5px solid var(--border-muted);
      color: var(--content-primary);
      font-family: var(--monospace);
      font-size: 0.7rem;
      padding: 0 var(--spacing-04);
      height: 1.75rem;
      width: 100%;
      max-width: 26rem;
      outline: none;
      letter-spacing: 0.02em;
    }
    .kits-search:focus { border-color: var(--border); }
    .kits-search::placeholder { color: var(--content-secondary-alt); }
    @media (max-width: 640px) {
      .kits-page { padding: 0 var(--spacing-05); }
      .kits-grid { grid-template-columns: 1fr; }
      .kits-search { max-width: 100%; }
    }
  </style>

  <script type="module">
    const filters = document.querySelectorAll('.kits-filter');
    const cards = document.querySelectorAll('.kit-card[data-complexity]');
    const searchInput = document.getElementById('kitsSearch');
    let activeFilter = 'all';
    let searchQuery = '';

    function applyFilters() {
      cards.forEach(card => {
        const matchComplexity = activeFilter === 'all' || card.dataset.complexity === activeFilter;
        const q = searchQuery.toLowerCase().trim();
        const matchSearch = !q ||
          card.querySelector('.kit-card-title')?.textContent.toLowerCase().includes(q) ||
          card.querySelector('.kit-card-desc')?.textContent.toLowerCase().includes(q);
        card.hidden = !(matchComplexity && matchSearch);
      });
    }

    filters.forEach(btn => {
      btn.addEventListener('click', () => {
        filters.forEach(b => b.classList.remove('kits-filter--active'));
        btn.classList.add('kits-filter--active');
        activeFilter = btn.dataset.filter;
        applyFilters();
      });
    });

    searchInput?.addEventListener('input', e => {
      searchQuery = e.target.value;
      applyFilters();
    });
  </script>
</Layout>
