---
import Layout from "../../layouts/Layout.astro";
import kitsData from "../../data/kits.json";
import catalog from "../../data/skills-catalog.json";
import slugMap from "../../data/slug-map.json";

export async function getStaticPaths() {
  return kitsData.kits.map(kit => ({ params: { id: kit.id } }));
}

export const prerender = true;

const { id } = Astro.params;
const kit = kitsData.kits.find(k => k.id === id);
if (!kit) throw new Error(`Kit not found: ${id}`);

type CatalogEntry = {
  title: string; description: string; useCase: string; chains: string[];
  snippet: string; endpoints: string[]; keyParams: Record<string,string>;
  responseFields: string[]; creditCost: string; complexity: string;
};
const cat = catalog as Record<string, CatalogEntry>;

// Build skills metadata
const skills = kit.skills
  .map(slug => ({ slug, ...(cat[slug] ?? { title: slug, description: '', useCase: '', chains: [], snippet: '', endpoints: [], keyParams: {}, responseFields: [], creditCost: '', complexity: 'Beginner' }) }))
  .filter(Boolean);

// Build combined prompt
const chainNameMap: Record<string, string> = {
  ethereum: "eth-mainnet", polygon: "matic-mainnet", base: "base-mainnet",
  arbitrum: "arbitrum-mainnet", optimism: "optimism-mainnet", bsc: "bsc-mainnet",
  avalanche: "avalanche-mainnet", solana: "solana-mainnet",
};
const allChains = [...new Set(skills.flatMap(s => s.chains))];
const chainOptions = allChains.slice(0, 8).map(c =>
  `{ label: "${c.charAt(0).toUpperCase() + c.slice(1)}", value: "${chainNameMap[c] ?? c + '-mainnet'}" }`
).join(', ');

const skillSections = skills.map((s, i) => {
  const epLine = s.endpoints.length > 0 ? `\n  Endpoint: ${s.endpoints[0]}` : '';
  const useLine = s.useCase ? `\n  Purpose: ${s.useCase}` : '';
  const snippetBlock = s.snippet
    ? `\n\n  Starting code:\n  \`\`\`typescript\n${s.snippet.split('\n').map((l: string) => '  ' + l).join('\n')}\n  \`\`\``
    : '';
  return `### ${i + 1}. ${s.title}${useLine}${epLine}${snippetBlock}`;
}).join('\n\n');

const combinedPrompt = `Build a production-ready "${kit.title}" web application using GoldRush.

## What to build
${kit.description}

## Skills to implement (${skills.length} total)

${skillSections}

## Architecture
- Next.js 14 App Router + TypeScript + Tailwind CSS
- @covalenthq/client-sdk (GoldRush SDK v3)
- Environment variable: GOLDRUSH_API_KEY
- Shared GoldRush client: lib/goldrush.ts
- Each skill = its own React component + custom hook
- Shared chain selector at top level

## Chain support
const CHAINS = [${chainOptions}];

When chain changes, all components re-fetch simultaneously.

## Requirements
1. Chain dropdown at page top — change re-fetches all
2. Loading skeleton per section
3. Error state per section with retry
4. Responsive grid layout
5. Full TypeScript — no any types

Build the complete app: all components, hooks, the main page, and shared utilities. Ready to deploy on Vercel.`;

const canonicalUrl = `https://skills.goldrush.dev/kits/${kit.id}`;
const slugMapTyped = slugMap as Record<string, string[]>;
const skillCategories = Object.fromEntries(
  skills.map(s => [s.slug, slugMapTyped[s.slug]?.[0] ?? ''])
);
---

<Layout
  site={`${kit.title} Starter Kit — GoldRush Skills`}
  title={kit.title}
  tagline={kit.description}
  pageTitle={`${kit.title} Starter Kit — GoldRush Skills`}
  pageDescription={`${kit.description} Includes ${kit.skills.length} GoldRush skills: ${skills.map(s => s.title).join(', ')}.`}
  canonicalUrl={canonicalUrl}
  ogTitle={`${kit.title} Starter Kit — GoldRush Skills`}
  ogDescription={kit.description}
>
  <main id="main-content" class="kit-page">
    <div class="kit-header">
      <a href="/kits" class="kit-back">← All kits</a>
      <div class="kit-badge-row">
        <span class="kit-emoji">{kit.emoji}</span>
        <span class={`kit-complexity kit-complexity--${kit.complexity.toLowerCase()}`}>{kit.complexity}</span>
        <span class="kit-chain-count">{allChains.length} chain{allChains.length !== 1 ? 's' : ''}</span>
      </div>
      <h1 class="kit-title">{kit.title}</h1>
      <p class="kit-description">{kit.description}</p>
      <div class="kit-chains">
        {allChains.map(c => <span class="kit-chain">{c}</span>)}
      </div>
      <div class="kit-cta-row">
        <button class="kit-build-btn" id="kitBuildBtn" data-skills={JSON.stringify(kit.skills)}>
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Start building with this kit
        </button>
        <span class="kit-build-hint">{kit.skills.length} skills added to your build cart</span>
      </div>
    </div>

    <!-- Skills included -->
    <section class="kit-section">
      <h2 class="kit-section-title">Skills included ({skills.length})</h2>
      <div class="kit-skills-grid">
        {skills.map(skill => {
          const category = skillCategories[skill.slug] ?? '';
          return (
            <a href={`/tools/${skill.slug}`} class="kit-skill-card">
              <span class="kit-skill-category">{category}</span>
              <strong class="kit-skill-title">{skill.title}</strong>
              <p class="kit-skill-desc">{skill.description}</p>
              <span class={`kit-skill-level kit-skill-level--${(skill.complexity ?? 'beginner').toLowerCase()}`}>
                {skill.complexity}
              </span>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Combined prompt -->
    <section class="kit-section">
      <div class="kit-prompt-block">
        <div class="kit-prompt-head">
          <span class="kit-prompt-label">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Combined Claude prompt
          </span>
          <button class="kit-copy-btn" id="kitCopyBtn">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="currentColor" viewBox="0 0 256 256"><path d="M216,32H88a8,8,0,0,0-8,8V80H40a8,8,0,0,0-8,8V216a8,8,0,0,0,8,8H168a8,8,0,0,0,8-8V176h40a8,8,0,0,0,8-8V40A8,8,0,0,0,216,32ZM160,208H48V96H160Zm48-48H176V88a8,8,0,0,0-8-8H96V48H208Z"/></svg>
            <span id="kitCopyLabel">Copy prompt</span>
          </button>
        </div>
        <p class="kit-prompt-hint">Paste into Claude → complete {kit.title} app with chain switching and all {skills.length} skills.</p>
        <textarea id="kitPromptText" readonly class="kit-prompt-textarea">{combinedPrompt}</textarea>
        <div class="kit-next-steps" id="kitNextSteps" style="display:none">
          <span class="kit-next-label">Next</span>
          <a href="https://claude.ai" target="_blank" rel="noopener noreferrer" class="kit-next-step">1 · Open Claude.ai →</a>
          <a href="https://goldrush.dev/platform/auth/register" target="_blank" rel="noopener noreferrer" class="kit-next-step">2 · Get free API key →</a>
          <a href="https://vercel.com/new" target="_blank" rel="noopener noreferrer" class="kit-next-step">3 · Deploy on Vercel →</a>
        </div>
      </div>
    </section>
  </main>

  <script type="module">
    // "Start building" → pre-load cart then go home
    const buildBtn = document.getElementById("kitBuildBtn");
    if (buildBtn) {
      buildBtn.addEventListener("click", () => {
        try {
          const skills = JSON.parse(buildBtn.dataset.skills || "[]");
          sessionStorage.setItem("build_cart", JSON.stringify(skills));
          window.gtag?.("event", "kit_start_building", { kit_id: window.location.pathname.split("/").pop(), skill_count: skills.length });
        } catch {}
        window.location.href = "/";
      });
    }

    const btn = document.getElementById("kitCopyBtn");
    const label = document.getElementById("kitCopyLabel");
    const textarea = document.getElementById("kitPromptText");
    const nextSteps = document.getElementById("kitNextSteps");
    if (btn && textarea) {
      btn.addEventListener("click", () => {
        navigator.clipboard.writeText(textarea.value).then(() => {
          if (label) { label.textContent = "Copied!"; setTimeout(() => label.textContent = "Copy prompt", 2500); }
          if (nextSteps) nextSteps.style.display = "flex";
          window.gtag?.("event", "kit_prompt_copy", { kit_id: window.location.pathname.split("/").pop() });
        });
      });
    }
  </script>

  <style>
    .kit-page { max-width: 52rem; margin: var(--spacing-08) auto; padding: 0 var(--spacing-09); }
    .kit-back { font-family: var(--monospace); font-size: 0.7rem; color: var(--content-secondary); text-decoration: none; }
    .kit-back:hover { color: var(--content-primary); }
    .kit-header { margin-bottom: var(--spacing-08); }
    .kit-badge-row { display: flex; align-items: center; gap: var(--spacing-03); margin: var(--spacing-04) 0 var(--spacing-03); }
    .kit-emoji { font-size: 1.25rem; }
    .kit-complexity { font-family: var(--monospace); font-size: 0.65rem; padding: 1px 7px; }
    .kit-complexity--beginner     { background: rgba(110,224,110,.08); color: #6ee06e; }
    .kit-complexity--intermediate { background: rgba(224,200,78,.08);  color: #e0c84e; }
    .kit-complexity--advanced     { background: rgba(224,110,110,.08); color: #e06e6e; }
    .kit-chain-count { font-family: var(--monospace); font-size: 0.65rem; color: var(--content-secondary-alt); }
    .kit-title { margin: 0 0 var(--spacing-03); font-size: 1.5rem; color: var(--content-primary); }
    .kit-description { margin: 0 0 var(--spacing-04); color: var(--content-secondary); font-size: var(--desktop-body-sm); line-height: 1.6; }
    .kit-chains { display: flex; flex-wrap: wrap; gap: var(--spacing-02); margin-bottom: var(--spacing-04); }
    .kit-cta-row { display: flex; align-items: center; gap: var(--spacing-04); flex-wrap: wrap; }
    .kit-build-btn { display: inline-flex; align-items: center; gap: var(--spacing-02); background: DarkOrange; border: none; color: #000; font-family: var(--monospace); font-size: 0.75rem; font-weight: 600; padding: 0 var(--spacing-05); height: 2rem; cursor: pointer; transition: opacity 0.15s; letter-spacing: 0.02em; }
    .kit-build-btn:hover { opacity: 0.88; }
    .kit-build-hint { font-family: var(--monospace); font-size: 0.65rem; color: var(--content-secondary-alt); }
    .kit-chain { font-family: var(--monospace); font-size: 0.65rem; padding: 1px 7px; background: var(--background); border: 0.5px solid var(--border-muted); color: var(--content-secondary-alt); }
    .kit-section { margin-bottom: var(--spacing-08); }
    .kit-section-title { font-size: 0.75rem; font-family: var(--monospace); color: var(--content-secondary-alt); letter-spacing: 0.06em; text-transform: uppercase; margin: 0 0 var(--spacing-04); font-weight: normal; }
    .kit-skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr)); gap: var(--spacing-03); }
    .kit-skill-card { display: flex; flex-direction: column; gap: var(--spacing-02); padding: var(--spacing-05); background: var(--background); border: 0.5px solid var(--border-muted); text-decoration: none; transition: border-color 0.15s; }
    .kit-skill-card:hover { border-color: var(--border); }
    .kit-skill-category { font-family: var(--monospace); font-size: 0.6rem; color: var(--content-secondary-alt); text-transform: uppercase; letter-spacing: 0.08em; }
    .kit-skill-title { color: var(--content-primary); font-size: var(--desktop-body-sm); }
    .kit-skill-desc { margin: 0; color: var(--content-secondary); font-size: var(--desktop-caption); line-height: 1.5; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .kit-skill-level { font-family: var(--monospace); font-size: 0.6rem; padding: 1px 6px; align-self: flex-start; }
    .kit-skill-level--beginner     { background: rgba(110,224,110,.08); color: #6ee06e; }
    .kit-skill-level--intermediate { background: rgba(224,200,78,.08);  color: #e0c84e; }
    .kit-skill-level--advanced     { background: rgba(224,110,110,.08); color: #e06e6e; }
    .kit-prompt-block { background: var(--background); border: 0.5px solid var(--border-muted); }
    .kit-prompt-head { display: flex; align-items: center; justify-content: space-between; padding: var(--spacing-03) var(--spacing-04); border-bottom: 0.5px solid var(--border-muted); }
    .kit-prompt-label { display: flex; align-items: center; gap: var(--spacing-02); font-family: var(--monospace); font-size: 0.7rem; color: var(--content-secondary); }
    .kit-copy-btn { display: inline-flex; align-items: center; gap: var(--spacing-02); background: DarkOrange; border: none; color: #000; font-family: var(--monospace); font-size: 0.65rem; font-weight: 600; padding: 0 var(--spacing-04); height: 1.5rem; cursor: pointer; transition: opacity 0.15s; }
    .kit-copy-btn:hover { opacity: 0.88; }
    .kit-prompt-hint { margin: 0; padding: var(--spacing-02) var(--spacing-04); font-family: var(--monospace); font-size: 0.65rem; color: var(--content-secondary-alt); border-bottom: 0.5px solid var(--border-muted); }
    .kit-prompt-textarea { width: 100%; min-height: 280px; background: var(--background); border: none; color: var(--content-secondary); font-family: var(--monospace); font-size: 0.65rem; line-height: 1.6; padding: var(--spacing-05); resize: vertical; outline: none; box-sizing: border-box; }
    .kit-next-steps { display: flex; align-items: center; gap: var(--spacing-04); padding: var(--spacing-03) var(--spacing-04); background: rgba(255,140,0,.04); border-top: 0.5px solid rgba(255,140,0,.15); flex-wrap: wrap; animation: fadeIn .2s ease; }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    .kit-next-label { font-family: var(--monospace); font-size: 0.6rem; color: var(--content-secondary-alt); text-transform: uppercase; letter-spacing: 0.06em; }
    .kit-next-step { font-family: var(--monospace); font-size: 0.65rem; color: DarkOrange; text-decoration: none; }
    .kit-next-step:hover { opacity: 0.75; }
    @media (max-width: 640px) {
      .kit-page { padding: 0 var(--spacing-05); }
      .kit-skills-grid { grid-template-columns: 1fr; }
    }
  </style>
</Layout>
